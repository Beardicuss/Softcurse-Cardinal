{
  "name": "cardinal",
  "version": "1.0.0",
  "description": "OS Commander & Companion — Softcurse Systems",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "puppeteer": "^24.40.0",
    "systeminformation": "^5.21.0"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.softcurse.cardinal",
    "productName": "Cardinal",
    "copyright": "Softcurse Systems",
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
